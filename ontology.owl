<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#"
     xml:base="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:untitled-ontology-2="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2">
        <rdfs:comment>Ontology for representing high-risk medical devices, incidents and corrective actions under MDR/IVDR regulations</rdfs:comment>
        <rdfs:label>Medical Device Ontology</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#affectsDevice -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#affectsDevice">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Device"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#hasCorrectiveAction -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#hasCorrectiveAction">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#CorrectiveAction"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#hasRiskClass -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#hasRiskClass">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Device"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#RiskClass"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#ActiveDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#ActiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Device"/>
        <rdfs:comment>Medical device that requires a source of energy to operate</rdfs:comment>
        <rdfs:label>ActiveDevice</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#BiologicalRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#BiologicalRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Risk"/>
        <rdfs:comment>Risk associated with biological contamination or reaction</rdfs:comment>
        <rdfs:label>BiologicalRisk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#ChemicalRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#ChemicalRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Risk"/>
        <rdfs:comment>Risk related to chemical substances or exposure</rdfs:comment>
        <rdfs:label>ChemicalRisk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#ClassI -->


    <owl:Class rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#ClassI">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#RiskClass"/>
        <rdfs:comment>Low risk medical device classification</rdfs:comment>
        <rdfs:label>ClassI</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#ClassIII -->


    <owl:Class rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#ClassIII">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#RiskClass"/>
        <rdfs:comment>High risk medical device classification</rdfs:comment>
        <rdfs:label>ClassIII</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#ClassIIa -->


    <owl:Class rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#ClassIIa">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#RiskClass"/>
        <rdfs:comment>Medium-low risk medical device classification</rdfs:comment>
        <rdfs:label>ClassIIa</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#ClassIIb -->


    <owl:Class rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#ClassIIb">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#RiskClass"/>
        <rdfs:comment>Medium-high risk medical device classification</rdfs:comment>
        <rdfs:label>ClassIIb</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#CorrectiveAction -->


    <owl:Class rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#CorrectiveAction">
        <rdfs:comment>Action taken to address or mitigate a reported incident</rdfs:comment>
        <rdfs:label>CorrectiveAction</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Device -->


    <owl:Class rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Device">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#hasRiskClass"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#RiskClass"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Medical device registered in the system</rdfs:comment>
        <rdfs:label>Device</rdfs:label>
        <rdfs:seeAlso>http://dbpedia.org/resource/Medical_device</rdfs:seeAlso>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#EuropeanManufacturer -->


    <owl:Class rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#EuropeanManufacturer">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Manufacturer"/>
        <rdfs:comment>Manufacturer located within the European Union</rdfs:comment>
        <rdfs:label>EuropeanManufacturer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#FieldCorrection -->


    <owl:Class rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#FieldCorrection">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#CorrectiveAction"/>
        <rdfs:comment>Action taken to correct a device already in use</rdfs:comment>
        <rdfs:label>FieldCorrection</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#HighPriorityIncident -->


    <owl:Class rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#HighPriorityIncident">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Incident"/>
        <rdfs:comment>Incident that requires urgent attention due to its severity</rdfs:comment>
        <rdfs:label>HighPriorityIncident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#HighRiskDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#HighRiskDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Device"/>
        <rdfs:comment>Medical device classified as high risk according to its risk class</rdfs:comment>
        <rdfs:label>HighRiskDevice</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#ImplantableDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#ImplantableDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Device"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Incident -->


    <owl:Class rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Incident">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#hasCorrectiveAction"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#CorrectiveAction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Event associated with a medical device that may cause risk or harm</rdfs:comment>
        <rdfs:label>Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Manufacturer -->


    <owl:Class rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Manufacturer">
        <rdfs:comment>Organization responsible for producing a medical device</rdfs:comment>
        <rdfs:label>Manufacturer</rdfs:label>
        <rdfs:seeAlso>http://dbpedia.org/resource/Manufacturer</rdfs:seeAlso>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#MechanicalRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#MechanicalRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Risk"/>
        <rdfs:comment>Risk related to mechanical failure or malfunction</rdfs:comment>
        <rdfs:label>MechanicalRisk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#MinorIncident -->


    <owl:Class rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#MinorIncident">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Incident"/>
        <rdfs:comment>Incident with limited or no significant impact on patient health</rdfs:comment>
        <rdfs:label>MinorIncident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#NonEuropeanManufacturer -->


    <owl:Class rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#NonEuropeanManufacturer">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Manufacturer"/>
        <rdfs:comment>Manufacturer located outside the European Union</rdfs:comment>
        <rdfs:label>NonEuropeanManufacturer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#NonImplantableDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#NonImplantableDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Device"/>
        <rdfs:comment>Medical device that is not intended to be implanted in the body</rdfs:comment>
        <rdfs:label>NonImplantableDevice</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Recall -->


    <owl:Class rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Recall">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#CorrectiveAction"/>
        <rdfs:comment>Action to remove a defective device from the market</rdfs:comment>
        <rdfs:label>Recall</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#ReportableIncident -->


    <owl:Class rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#ReportableIncident">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Incident"/>
        <rdfs:comment>Incident that must be reported to regulatory authorities</rdfs:comment>
        <rdfs:label>ReportableIncident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Risk -->


    <owl:Class rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Risk">
        <rdfs:comment>Potential hazard associated with the use of a medical device</rdfs:comment>
        <rdfs:label>Risk</rdfs:label>
        <rdfs:seeAlso>http://dbpedia.org/resource/Risk</rdfs:seeAlso>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#RiskClass -->


    <owl:Class rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#RiskClass">
        <rdfs:comment>Classification category that defines the risk level of a medical device</rdfs:comment>
        <rdfs:label>RiskClass</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#SafetyAlert -->


    <owl:Class rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#SafetyAlert">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#CorrectiveAction"/>
        <rdfs:comment>Notification issued to warn about a potential risk</rdfs:comment>
        <rdfs:label>SafetyAlert</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#SafetyMonitoredIncident -->


    <owl:Class rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#SafetyMonitoredIncident">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Incident"/>
        <rdfs:comment>Incident that is under monitoring after corrective actions have been applied</rdfs:comment>
        <rdfs:label>SafetyMonitoredIncident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#SeriousIncident -->


    <owl:Class rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#SeriousIncident">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Incident"/>
        <rdfs:comment>Incident that leads to serious consequences such as death or serious deterioration of health</rdfs:comment>
        <rdfs:label>SeriousIncident</rdfs:label>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#ActiveImplant -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#ActiveImplant">
        <rdf:type rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Device"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#ImplantableDevice -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#ImplantableDevice">
        <rdf:type rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Device"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#action_1 -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#action_1">
        <rdf:type rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#CorrectiveAction"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#classIII_1 -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#classIII_1">
        <rdf:type rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#ClassIII"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#device_1 -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#device_1">
        <rdf:type rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Device"/>
        <hasRiskClass rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#classIII_1"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#incident_1 -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#incident_1">
        <rdf:type rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#Incident"/>
        <affectsDevice rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#device_1"/>
        <hasCorrectiveAction rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#action_1"/>
    </owl:NamedIndividual>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotations
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <rdf:Description rdf:about="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#ImplantableDevice">
        <rdfs:comment>Medical device intended to be placed inside the human body</rdfs:comment>
        <rdfs:label>ImplantableDevice</rdfs:label>
    </rdf:Description>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Rules
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <rdf:Description rdf:about="urn:swrl:var#d">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="urn:swrl:var#i">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="urn:swrl:var#a">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#HighPriorityIncident"/>
                        <swrl:argument1 rdf:resource="urn:swrl:var#i"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/juanl/ontologies/2026/3/untitled-ontology-2#hasCorrectiveAction"/>
                                <swrl:argument1 rdf:resource="urn:swrl:var#i"/>
                                <swrl:argument2 rdf:resource="urn:swrl:var#a"/>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                    </rdf:Description>
                </rdf:rest>
            </rdf:Description>
        </swrl:body>
        <swrl:head>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
